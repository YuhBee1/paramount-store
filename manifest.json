    }
  ],
  "screenshots": [
    {
      "src": "images/logo.png",
      "sizes": "400x400",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Paramount E-mart — Shop Electronics & Home Appliances in Uyo"
    },
    {
      "src": "images/logo.png",
      "sizes": "400x400",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Paramount E-mart — Nigeria's Premium Appliance Store"
