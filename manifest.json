  "shortcuts": [
    {
      "name": "Shop Now",
      "short_name": "Shop",
      "description": "Browse all products",
      "url": "/?catalogue=all",
      "icons": [{ "src": "images/icons/icon-96.png", "sizes": "96x96" }]
    },
    {
      "name": "Track Order",
      "short_name": "Track",
      "description": "Track your shipment",
      "url": "/tracking.html",
      "icons": [{ "src": "images/icons/icon-96.png", "sizes": "96x96" }]
    },
    {
